{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      ".read": "auth != null && auth.token.email === 'martialfabrice@tino-le-doc.com'",
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid",
        ".validate": "newData.hasChildren(['email', 'pseudo', 'createdAt'])"
      }
    },
    "pseudos": {
      ".read": true,
      "$pseudo": {
        ".write": "auth != null && (!data.exists() || data.val() == auth.uid)",
        ".validate": "newData.val() == auth.uid"
      }
    },
    "counters": {
      "visits": {
        ".read": true,
        ".write": true,
        ".validate": "newData.isNumber()"
      },
      "subscribers": {
        ".read": true,
        ".write": "auth != null",
        ".validate": "newData.isNumber()"
      },
      "iotQuestions": {
        ".read": true,
        ".write": "auth != null",
        ".validate": "newData.isNumber()"
      }
    },
    "contactMessages": {
      ".read": "auth != null && auth.token.email === 'martialfabrice@tino-le-doc.com'",
      ".write": true,
      ".indexOn": ["timestamp"],
      "$msgId": {
        ".validate": "newData.hasChildren(['name', 'email', 'message', 'timestamp'])"
      }
    },
    "chatMessages": {
      ".read": true,
      ".write": "auth != null",
      ".indexOn": ["timestamp"],
      "$msgId": {
        ".validate": "newData.hasChildren(['text', 'pseudo', 'timestamp']) && newData.child('text').isString() && newData.child('text').val().length <= 1000"
      }
    },
    "chatUsers": {
      ".read": true,
      "$userId": {
        ".write": "auth != null && auth.uid == $userId"
      }
    },
    "chatTyping": {
      ".read": true,
      "$userId": {
        ".write": "auth != null && auth.uid == $userId"
      }
    },
    "reviews": {
      ".read": true,
      ".write": "auth != null",
      ".indexOn": ["timestamp"],
      "$reviewId": {
        ".validate": "newData.hasChildren(['text', 'rating', 'timestamp']) && newData.child('rating').isNumber() && newData.child('rating').val() >= 1 && newData.child('rating').val() <= 5 && newData.child('text').isString() && newData.child('text').val().length <= 2000"
      }
    },
    "contacts": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && auth.uid == $userId"
      }
    },
    "friendRequests": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null"
      }
    },
    "userConversations": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null"
      }
    },
    "dmMessages": {
      "$convId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".indexOn": ["timestamp"],
        "$msgId": {
          ".validate": "newData.hasChildren(['text', 'senderId', 'timestamp']) && newData.child('text').isString() && newData.child('text').val().length <= 5000"
        }
      }
    },
    "groups": {
      "$groupId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "groupMessages": {
      "$groupId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".indexOn": ["timestamp"]
      }
    },
    "dmVideoRoom": {
      "$convId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "groupVideoRoom": {
      "$groupId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "incomingCalls": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null"
      }
    },
    "quizScores": {
      ".read": true,
      ".write": "auth != null",
      ".indexOn": ["accuracy", "timestamp"],
      "$scoreId": {
        ".validate": "newData.hasChildren(['pseudo', 'accuracy', 'timestamp']) && newData.child('accuracy').isNumber()"
      }
    },
    "polls": {
      ".read": true,
      "$pollId": {
        ".write": "auth != null",
        "votes": {
          "$optionId": {
            ".write": "auth != null"
          }
        },
        "totalVotes": {
          ".write": "auth != null"
        }
      }
    },
    "dailyVotes": {
      ".read": true,
      "$date": {
        ".write": "auth != null"
      }
    },
    "debates": {
      ".read": true,
      "$date": {
        ".write": "auth != null",
        "pour": {
          ".write": "auth != null"
        },
        "contre": {
          ".write": "auth != null"
        }
      }
    },
    "debateArguments": {
      ".read": true,
      "$date": {
        ".write": "auth != null",
        ".indexOn": ["likes", "timestamp"],
        "$argId": {
          ".write": "auth != null",
          "likes": {
            ".write": "auth != null"
          }
        }
      }
    },
    "forumGroups": {
      ".read": "auth != null",
      ".indexOn": ["category", "createdAt", "memberCount", "isPublic"],
      "$groupId": {
        ".write": "auth != null"
      }
    },
    "forumMembers": {
      "$groupId": {
        ".read": "auth != null",
        "$userId": {
          ".write": "auth != null"
        }
      }
    },
    "forumMessages": {
      "$groupId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".indexOn": ["timestamp", "isPinned"]
      }
    },
    "forumInvites": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null",
        ".indexOn": ["timestamp"]
      }
    },
    "pushSubscriptions": {
      ".read": "auth != null && auth.token.email === 'martialfabrice@tino-le-doc.com'",
      ".write": true,
      "$subId": {
        ".validate": "newData.hasChildren(['endpoint', 'keys', 'createdAt']) && newData.child('endpoint').isString() && newData.child('endpoint').val().length < 2000 && newData.child('createdAt').isNumber()"
      }
    },
    "veilleArticles": {
      ".read": true,
      ".indexOn": ["timestamp", "likesCount", "category"],
      ".write": "auth != null && auth.token.email === 'martialfabrice@tino-le-doc.com'",
      "$articleId": {
        "likes": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "likesCount": {
          ".write": "auth != null"
        }
      }
    },
    "creations": {
      ".read": "auth != null",
      ".indexOn": ["timestamp", "category", "authorId"],
      "$creationId": {
        ".write": "auth != null && (!data.exists() || data.child('authorId').val() == auth.uid || auth.token.email === 'martialfabrice@tino-le-doc.com')",
        ".validate": "newData.hasChildren(['title', 'category', 'authorId', 'authorPseudo', 'timestamp']) && newData.child('title').isString() && newData.child('title').val().length >= 1 && newData.child('title').val().length <= 100 && newData.child('category').isString() && newData.child('desc').isString() && newData.child('desc').val().length <= 2000",
        "likesCount": {
          ".write": "auth != null"
        }
      }
    },
    "creationLikes": {
      "$creationId": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && auth.uid == $uid"
        }
      }
    },
    "creationComments": {
      "$creationId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".indexOn": ["timestamp"],
        "$commentId": {
          ".validate": "newData.hasChildren(['text', 'authorId', 'authorPseudo', 'timestamp']) && newData.child('text').isString() && newData.child('text').val().length >= 1 && newData.child('text').val().length <= 500"
        }
      }
    }
  }
}
