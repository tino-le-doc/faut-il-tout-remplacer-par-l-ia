# =============================================================================
# Nginx Configuration for tino-le-doc.com
# =============================================================================
# Cache Control, Security, Compression, and Performance Optimizations
# Deploy to: /etc/nginx/sites-available/tino-le-doc.com (or your domain)
# =============================================================================

# HTTP Server Block (redirect to HTTPS)
server {
    listen 80;
    listen [::]:80;
    server_name tino-le-doc.com www.tino-le-doc.com;
    
    # Redirect all HTTP to HTTPS
    return 301 https://$server_name$request_uri;
}

# HTTPS Server Block (main configuration)
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    
    server_name tino-le-doc.com www.tino-le-doc.com;
    root /var/www/tino-le-doc.com/html;
    index index.html index.htm;
    
    # ==========================================================================
    # SSL/TLS Configuration (adjust paths for your certificates)
    # ==========================================================================
    ssl_certificate /etc/letsencrypt/live/tino-le-doc.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/tino-le-doc.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    
    # HSTS (HTTP Strict Transport Security)
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    
    # ==========================================================================
    # COMPRESSION - Enable Gzip for faster content delivery
    # ==========================================================================
    gzip on;
    gzip_vary on;
    gzip_min_length 256;
    gzip_comp_level 6;
    gzip_types text/plain text/css text/xml text/javascript 
               application/json application/javascript application/xml+rss 
               application/rss+xml font/truetype font/opentype 
               application/vnd.ms-fontobject image/svg+xml;
    
    # ==========================================================================
    # SECURITY HEADERS
    # ==========================================================================
    
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;
    
    # Content-Security-Policy
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' https://www.googletagmanager.com https://www.gstatic.com https://fonts.googleapis.com https://pagead2.googlesyndication.com 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://firebase.google.com https://www.google-analytics.com https://www.googletagmanager.com wss:; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self';" always;
    
    # ==========================================================================
    # LOGGING
    # ==========================================================================
    access_log /var/log/nginx/tino-le-doc-access.log combined;
    error_log /var/log/nginx/tino-le-doc-error.log warn;
    
    # ==========================================================================
    # CACHE CONTROL - Browser caching for static assets
    # ==========================================================================
    
    # IMAGES (AVIF, WebP, PNG, GIF, JPG) - Cache 1 year (immutable)
    location ~* \.(avif|webp|png|gif|jpg|jpeg|svg|ico)$ {
        expires 1y;
        add_header Cache-Control "public, max-age=31536000, immutable" always;
        add_header Vary "Accept-Encoding" always;
    }
    
    # VIDEO FILES (MP4, WebM, OGV) - Cache 30 days
    location ~* \.(mp4|webm|ogv|mov|avi)$ {
        expires 30d;
        add_header Cache-Control "public, max-age=2592000" always;
        add_header Vary "Accept-Encoding" always;
    }
    
    # CSS & JAVASCRIPT - Cache 30 days
    location ~* \.(css|js)$ {
        expires 30d;
        add_header Cache-Control "public, max-age=2592000" always;
        add_header Vary "Accept-Encoding" always;
    }
    
    # FONTS (Google Fonts, local) - Cache 1 year (immutable)
    location ~* \.(woff|woff2|ttf|otf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, max-age=31536000, immutable" always;
        add_header Vary "Accept-Encoding" always;
        add_header Access-Control-Allow-Origin "*" always;
    }
    
    # MANIFESTS & DATA - Cache 30 days
    location ~* \.(json|xml|webmanifest)$ {
        expires 30d;
        add_header Cache-Control "public, max-age=2592000" always;
        add_header Vary "Accept-Encoding" always;
    }
    
    # HTML FILES - Cache 1 hour (must revalidate)
    location ~* \.html?$ {
        expires 1h;
        add_header Cache-Control "public, max-age=3600, must-revalidate" always;
        add_header Vary "Accept-Encoding" always;
    }
    
    # SERVICE WORKER - Cache 1 hour (must revalidate)
    location = /sw.js {
        expires 1h;
        add_header Cache-Control "public, max-age=3600, must-revalidate" always;
        add_header Vary "Accept-Encoding" always;
    }
    
    # DATABASE RULES & CONFIG - No caching
    location ~ (\.rules|database\.rules\.json|storage\.rules)$ {
        add_header Cache-Control "no-cache, no-store, must-revalidate" always;
        add_header Pragma "no-cache" always;
        add_header Expires "0" always;
    }
    
    # ==========================================================================
    # DENY ACCESS TO SENSITIVE FILES
    # ==========================================================================
    
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }
    
    location ~ (\.env|firebase\.json|database\.rules\.json|storage\.rules) {
        deny all;
        access_log off;
        log_not_found off;
    }
    
    # ==========================================================================
    # URL REWRITING & ROUTING
    # ==========================================================================
    
    # Redirect www to non-www (optional)
    if ($host = www.tino-le-doc.com) {
        return 301 https://tino-le-doc.com$request_uri;
    }
    
    # Single Page App routing (if needed)
    location / {
        try_files $uri $uri/ /index.html;
    }
    
    # ==========================================================================
    # ERROR HANDLING
    # ==========================================================================
    
    error_page 404 /404.html;
    error_page 500 502 503 504 /50x.html;
    
    location = /50x.html {
        # This location has a default MIME type
    }
}
